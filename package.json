    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-table": "^8.21.3",
    "bullmq": "^5.80.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.42.2",
    "googleapis": "^173.0.0",
    "ioredis": "^5.11.1",
    "lucide-react": "^1.25.0",
    "mammoth": "^1.12.0",
