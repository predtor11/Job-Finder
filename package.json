{
  "name": "job-finder",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered job application automation platform — job discovery, resume-aware personalization, Gmail outreach with approval workflows, and a full application CRM.",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint src workers tests",
    "typecheck": "tsc --noEmit",
    "worker": "tsx workers/index.ts",
    "worker:dev": "tsx watch workers/index.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
