# ──────────────────────────────────────────────────────────────────────────────
# Job Finder — Environment Configuration
# Copy to .env.local for Next.js, and .env for Prisma CLI / workers.
# NEVER commit real values.
# ──────────────────────────────────────────────────────────────────────────────

# ─── Supabase ────────────────────────────────────────────────────────────────
# From: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
# Service role key — server-side only. Bypasses RLS; never expose to the client.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ─── Database (Prisma) ───────────────────────────────────────────────────────
# From: Supabase Dashboard → Project Settings → Database → Connection string
# Pooled connection (PgBouncer, port 6543) for the app:
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Direct connection (port 5432) for migrations:
DIRECT_URL="postgresql://postgres.YOUR_PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# ─── Gemini (Google AI Studio) ───────────────────────────────────────────────
# NOTE: there is NO shared server key. Every user configures their own free
# key in Settings → AI (stored encrypted per account). Only the model
# defaults below are read from the environment.
# Model used for cheap extraction/classification tasks ("-latest" aliases
# track Google's current stable release, so model sunsets can't break the app):
GEMINI_FAST_MODEL="gemini-flash-lite-latest"
# Model used for generation (cover letters, emails, resume analysis):
GEMINI_SMART_MODEL="gemini-flash-latest"

# ─── Gmail OAuth ─────────────────────────────────────────────────────────────
# From: Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client
# Enable the Gmail API, add scopes: gmail.send, gmail.readonly, gmail.modify
GOOGLE_CLIENT_ID="your-google-oauth-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-oauth-client-secret"
# Must match an Authorized redirect URI on the OAuth client:
GOOGLE_REDIRECT_URI="http://localhost:3000/api/gmail/callback"

# ─── Encryption ──────────────────────────────────────────────────────────────
# 32-byte hex key for AES-256-GCM encryption of OAuth tokens at rest.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="64-hex-characters"

# ─── Redis (BullMQ background jobs) ──────────────────────────────────────────
# Local: docker compose up redis   |   Prod: Upstash / Railway / Redis Cloud
REDIS_URL="redis://localhost:6379"

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Secret used to authenticate Vercel Cron / external schedulers calling internal APIs:
CRON_SECRET="generate-a-long-random-string"


